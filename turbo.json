{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "tsconfig.build.tsbuildinfo"]
    },
    "@metamask/browser-playground#build": {
      "dependsOn": ["^build"],
      "outputs": ["build/**"]
    },
    "@metamask/react-native-playground#build": {
      "dependsOn": ["^build"],
      "outputs": [],
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:verbose": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:ci": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "build:docs": {
      "dependsOn": ["build"],
      "outputs": ["docs/**"]
    },
    "changelog:validate": {
      "inputs": ["CHANGELOG.md", "package.json"],
      "outputs": []
    },
    "changelog:format": {
      "outputs": []
    },
    "changelog:update": {
      "outputs": []
    }
  },
  "ui": "stream"
}
